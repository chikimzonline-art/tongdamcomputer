# ============================================================
#  .env.example — Copy this file to .env and fill in values
#  DO NOT commit .env — it is listed in .gitignore
# ============================================================

# --- Database (Vercel Postgres / Neon) ---
# POSTGRES_PRISMA_URL uses connection pooling (for serverless environments)
POSTGRES_PRISMA_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require
# POSTGRES_URL_NON_POOLING direct connection URL (for migrations and push)
POSTGRES_URL_NON_POOLING=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require

# --- NextAuth ---
# Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-strong-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# --- UploadThing ---
# Get your token from: https://dashboard.uploadthing.com
# It is a base64-encoded JSON token (starts with "eyJ...")
UPLOADTHING_TOKEN=your-uploadthing-token-here
